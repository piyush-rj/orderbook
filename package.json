{
    "name": "orderbook",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "prettier --write --tab-width 4 \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css}\"",
        "format:check": "prettier --check --tab-width 4 \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css}\"",
        "check-types": "turbo run check-types"
    },
    "devDependencies": {
        "prettier": "^3.7.4",
        "turbo": "^2.9.12",
        "typescript": "5.9.2"
    },
    "engines": {
        "node": ">=18"
    },
    "packageManager": "bun@1.3.9",
    "workspaces": [
        "apps/*",
        "packages/*"
    ]
}
